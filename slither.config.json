{
  "detectors_to_run": [
    "reentrancy-eth",
    "reentrancy-no-eth",
    "integer-overflow",
    "unchecked-transfer",
    "arbitrary-send",
    "controlled-delegatecall",
    "suicidal",
    "uninitialized-state",
    "uninitialized-storage",
    "locked-ether",
    "tx-origin"
  ],
  "detectors_to_exclude": "naming-convention,solc-version,low-level-calls",
  "exclude_informational": false,
  "exclude_low": false,
  "filter_paths": "node_modules,test",
  "json": "slither-report.json",
  "sarif": "slither-report.sarif",
  "fail_on": "high"
}
